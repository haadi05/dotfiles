{
  //no telemetry
  "telemetry.telemetryLevel": "off",
  "rest-client.enableTelemetry": false,
  "telemetry.feedback.enabled": false,

  //vim extention performance
  "extensions.experimental.affinity": {
    "vscodevim.vim": 1
  },

  //vim configurations
  "editor.lineNumbers": "relative",
  "vim.useSystemClipboard": true,
  "vim.hlsearch": true,
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<Esc>"],
      "when": ["editorFocus"],
      "commands": [":nohl"],
      "silent": true
    }
  ],

  //disable ai features
  "chat.disableAIFeatures": true,
  "workbench.secondarySideBar.defaultVisibility": "hidden",

  //font
  "editor.fontSize": 14,
  "editor.fontFamily": "'JetBrainsMono Nerd Font', 'Droid Sans Mono', monospace",
  "editor.lineHeight": 20,
  "editor.fontLigatures": true,

  //hide top cluter
  "window.titleBarStyle": "native",
  "window.menuBarVisibility": "toggle",
  "window.customTitleBarVisibility": "never",

  //ui
  "window.zoomLevel": 1,
  "workbench.editor.empty.hint": "hidden",
  "workbench.activityBar.location": "hidden",
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": false,
  "editor.minimap.enabled": false,
  "breadcrumbs.enabled": false,

  //tab ui
  "workbench.editor.tabActionCloseVisibility": false,
  "window.density.editorTabHeight": "compact",

  //side bar
  "workbench.sideBar.location": "right",
  "workbench.iconTheme": "charmed-warm",
  "charmed-icons.hidesExplorerArrows": true,
  "workbench.tree.indent": 12,
  "explorer.compactFolders": false,
  "explorer.confirmDragAndDrop": false,

  //use system remaps
  "keyboard.dispatch": "keyCode",

  //behavior (formatting, cursor, scrollbar)
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "[json][jsonc]": {
    "prettier.trailingComma": "none"
  },

  "editor.cursorBlinking": "solid",

  "editor.scrollbar.vertical": "hidden",
  "editor.scrollbar.horizontal": "hidden",

  "files.trimTrailingWhitespace": true,
  "editor.showFoldingControls": "never",
  "js/ts.updateImportsOnFileMove.enabled": "never",

  //auto rename closing tag
  "editor.linkedEditing": true,

  //terminal
  "terminal.integrated.initialHint": false,
  "terminal.integrated.defaultLocation": "editor",

  //italic fonts
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "comment",
        "settings": {
          "fontStyle": "italic"
        }
      }
    ]
  },
  "workbench.colorCustomizations": {
    "[Nord Wave]": {
      "editor.background": "#181818",
      "sideBar.background": "#181818",
      "tab.activeBackground": "#181818",
      "editorGroupHeader.tabsBackground": "#181818",
      "tab.inactiveBackground": "#181818",
      "tab.unfocusedActiveBackground": "#181818",
      "tab.unfocusedInactiveBackground": "#181818",
      "statusBar.noFolderBackground": "#181818",
      "statusBar.background": "#181818",
      "terminal.background": "#181818",
      "terminal.border": "#181818",
      "panel.background": "#181818",

      "sideBar.foreground": "#CCCCCC",
      "list.activeSelectionBackground": "#00000000",
      "list.focusBackground": "#00000000",
      "list.focusOutline": "#88c0d0",
      "editor.lineHighlightBackground": "#00000000",
      "editor.lineHighlightBorder": "#2c2c2c"
    }
  },
  "workbench.colorTheme": "Nord Wave"
}
